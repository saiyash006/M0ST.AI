# M0ST Environment Configuration
# Copy to .env and fill in your values: cp .env.example .env

SQLITE_DB=storage/metadata.db

# Optional: path to radare2 / gdb / ghidra if not in PATH
R2_PATH=
GDB_PATH=
GHIDRA_PATH=

# Optional: override pipeline timeout seconds
PIPELINE_EVENT_TIMEOUT=10

# LLM provider configuration (optional)
# Supported providers: openai, anthropic, mistral, local, none
LLM_PROVIDER=none
LLM_MODEL=
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
MISTRAL_API_KEY=
LLM_BASE_URL=       # for local/Ollama: http://localhost:11434/v1
